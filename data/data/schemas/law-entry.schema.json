{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://talush.app/schemas/law-entry.schema.json",
  "title": "Talush Law Entry",
  "description": "מבנה נתונים אחיד לחוק/זכאות במערכת תלוש",
  "type": "object",
  "required": ["id", "category", "title", "effective_from", "rules", "sources", "metadata", "legal_disclaimer"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "מזהה ייחודי, lowercase + hyphens"
    },
    "category": {
      "type": "string",
      "enum": ["tax", "reserves", "students", "parental", "pension", "labor", "social", "periphery", "other"]
    },
    "subcategory": {
      "type": ["string", "null"]
    },
    "title": {
      "type": "string",
      "description": "כותרת בעברית"
    },
    "title_en": {
      "type": ["string", "null"],
      "description": "כותרת באנגלית (אופציונלי)"
    },
    "description": {
      "type": "string",
      "description": "תיאור החוק/זכאות בעברית פשוטה"
    },
    "effective_from": {
      "type": "string",
      "format": "date",
      "description": "תאריך תחילת תוקף"
    },
    "effective_until": {
      "type": ["string", "null"],
      "format": "date"
    },
    "retroactive": {
      "type": "boolean",
      "default": false
    },
    "retroactive_from": {
      "type": ["string", "null"],
      "format": "date"
    },
    "rules": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["credit_points", "tax_exemption", "deduction", "grant", "rate", "minimum", "maximum", "calculation", "eligibility"]
        },
        "value": {
          "type": ["number", "string", "object", "null"]
        },
        "unit": {
          "type": ["string", "null"],
          "examples": ["NIS/month", "NIS/year", "%", "points", "days", "hours"]
        },
        "conditions": {
          "type": "object",
          "description": "תנאי זכאות — מבנה חופשי"
        },
        "calculation": {
          "type": ["string", "null"],
          "description": "נוסחת חישוב טקסטואלית"
        },
        "calculation_fn": {
          "type": ["string", "null"],
          "description": "שם פונקציית JS שמחשבת (אם יש)"
        }
      }
    },
    "applies_to": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "all_employees", "single_parent", "married", "with_children",
          "reservist", "student_bachelor", "student_masters", "student_phd",
          "olim_chadashim", "discharged_soldier", "minimum_wage_earner",
          "shift_worker", "periphery_resident", "disabled", "tax_residents",
          "private_sector", "all"
        ]
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url", "fetched_at"],
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "document_id": { "type": ["string", "null"] },
          "fetched_at": { "type": "string", "format": "date-time" },
          "snapshot_hash": { "type": ["string", "null"] }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["first_seen", "last_updated", "version"],
      "properties": {
        "first_seen": { "type": "string", "format": "date-time" },
        "last_updated": { "type": "string", "format": "date-time" },
        "version": { "type": "integer", "minimum": 1 },
        "ai_confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "human_reviewed": { "type": "boolean", "default": false },
        "reviewer_notes": { "type": ["string", "null"] },
        "expert_approved": { "type": "boolean", "default": false }
      }
    },
    "impact_estimate": {
      "type": ["object", "null"],
      "properties": {
        "users_affected": { "type": "string" },
        "average_correction_nis": { "type": ["number", "null"] }
      }
    },
    "legal_disclaimer": {
      "type": "string",
      "description": "disclaimer משפטי קצר עם הפניה למקור הרישמי"
    }
  }
}
