{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/ocr.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/", "destination": "/marketing/index.html" },
    { "source": "/landing", "destination": "/marketing/index.html" },
    { "source": "/login", "destination": "/marketing/Login.html" },
    { "source": "/signup", "destination": "/marketing/Signup.html" },
    { "source": "/forgot-password", "destination": "/marketing/ForgotPassword.html" },
    { "source": "/dashboard", "destination": "/marketing/Dashboard.html" },
    { "source": "/tax-profile", "destination": "/marketing/TaxProfile.html" },
    { "source": "/calculator", "destination": "/marketing/NetCalculator.html" },
    { "source": "/rights", "destination": "/marketing/Rights.html" },
    { "source": "/legal", "destination": "/marketing/Legal.html" },
    { "source": "/admin", "destination": "/marketing/Admin.html" },
    { "source": "/audit", "destination": "/marketing/Audit.html" },
    { "source": "/404", "destination": "/marketing/404.html" },
    { "source": "/((?!api|marketing|assets).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://vercel.live https://cdn.tailwindcss.com https://unpkg.com https://cdnjs.cloudflare.com https://esm.sh; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://accounts.google.com https://ipapi.co; frame-src https://vercel.live https://accounts.google.com; worker-src 'self' blob:; media-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://accounts.google.com https://*.supabase.co" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
