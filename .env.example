# =====================================================================
# TLUSH Free Sector — Environment Variables
# Full setup guide: docs/SETUP.md
# =====================================================================

# ── Supabase (REQUIRED) ───────────────────────────────────────────────
# Both VITE_* and bare names — VITE_* is for client (build-time inject),
# bare names are for Vercel Functions (server-side).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# Server-side (Vercel Functions) — same values as VITE_* duplicated
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# Service role key — bypasses RLS for server-only operations.
# Get from Supabase Dashboard → Settings → API → service_role.
# NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# ── Demo mode (dev only) ──────────────────────────────────────────────
# Set true to use in-memory demo user (skips Supabase entirely).
VITE_DEMO_AUTH=false

# ── OCR (optional — /api/ocr returns 503 without these) ───────────────
# Google Cloud Vision API key. Console: cloud.google.com/vision
GOOGLE_VISION_API_KEY=

# Anthropic API key for Claude Haiku. Console: console.anthropic.com
ANTHROPIC_API_KEY=

# ── Geo-block bypass (optional invite tokens) ────────────────────────
# Comma-separated tokens that grant bypass via ?invite=<token>
# Example: GEO_BYPASS_TOKENS=beta-2026-token-1,beta-2026-token-2
GEO_BYPASS_TOKENS=

# ── Observability (optional) ─────────────────────────────────────────
# Web Vitals beacon endpoint (POSTs LCP/INP/CLS JSON). Falls back to
# console.log if blank.
VITE_WEB_VITALS_ENDPOINT=

# Release tag/SHA — populates error_logs.release for triage.
VITE_APP_RELEASE=

# ── Tranzila payments (Phase 10 — defer until merchant approved) ─────
# TRANZILA_SUPPLIER=
# TRANZILA_PAGE_CODE=
# TRANZILA_HMAC_SECRET=

# ── Future: VPN detection + distributed rate-limit (Phase 11+) ───────
# IPQS_API_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
