# Supabase (required unless VITE_DEMO_AUTH=true)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Demo mode — bypass Supabase + use in-memory user (dev/smoke only)
VITE_DEMO_AUTH=false

# Optional: error_logs.release column (e.g. git SHA, semver tag)
VITE_APP_RELEASE=

# Optional: Web Vitals beacon endpoint (POSTs metric JSON). Console-only if blank.
VITE_WEB_VITALS_ENDPOINT=
